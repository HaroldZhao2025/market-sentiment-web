    "raw": {
      "id": "0c98e9af-2483-3bc4-aa95-3ef627a34485",
      "content": {
        "id": "0c98e9af-2483-3bc4-aa95-3ef627a34485",
        "contentType": "STORY",
        "title": "Albemarle (ALB) Q1 2026 Earnings Transcript",
        "description": "",
